# ── Basis ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./goathub.db
JWT_SECRET=                      # openssl rand -hex 32
ENCRYPTION_KEY=                  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Key-Rotation (M-15): kommaseparierte Fernet-Keys, NEUESTER ZUERST.
# encrypt nutzt den ersten, decrypt probiert alle. Wenn gesetzt, überstimmt
# das ENCRYPTION_KEY/+_OLD. Beispiel: ENCRYPTION_KEYS=neuerKey,alterKey
#ENCRYPTION_KEYS=

# ── Hyperliquid ──────────────────────────────────────────────────────────────
HL_TESTNET=true                  # true = Testnet (Spielgeld). false = MAINNET (echtes Geld!)

# ── Referral / Builder-Code (DEIN Gebühren-Anteil) ──────────────────────────
BUILDER_ADDRESS=                 # deine HL-Master-Adresse (braucht >=100 USDC perps, um Fees zu kassieren)
BUILDER_FEE=0.1%                 # Perps-Maximum (= 100 bps = f:100). Hard-cap in fee_to_int — höher → ValueError.

# ── Signal-Quelle (#signals von Bot 1, privat) ──────────────────────────────
DISCORD_BOT_TOKEN=               # Token eines Bots, der #signals mitlesen darf (Message Content Intent!)
SIGNALS_CHANNEL_ID=1508990889589080294
ENABLE_LISTENER=false            # false = nur API/Dashboard (localhost). true = Live-Trading scharf.
SIGNAL_BACKFILL=true             # beim (Re)Connect verpasste #signals-Messages nachholen; false = nur Live-Messages
ENABLE_DOCS=false                # /docs, /redoc, /openapi.json — leakt API-Surface; nur lokal auf true

# ── Defaults für neue Nutzer ─────────────────────────────────────────────────
# 2026-06-12 (#40): an die gehärteten config.py-Defaults (B1, 2026-06-08)
# angeglichen. Vorher stand hier 0.01 / 3 / 10 — wer per README
# `cp .env.example .env` machte, verdoppelte still Risiko + Max-Positionen
# jedes neuen Users und hebelte die Härtung wieder aus.
DEFAULT_RISK_PCT=0.005              # 0.5% Risiko pro Trade (konservativ für neue User)
DEFAULT_LEVERAGE=20                 # ACHTUNG: seit 2026-06-06 die Auto-Leverage-OBERGRENZE (Cap), KEIN fixer Hebel — Auto-Lev passt sich an SL+Confidence an
DEFAULT_MAX_OPEN=5                  # max. gleichzeitig offene Positionen pro User
MIN_NOTIONAL_USDC=10
MIN_CONFIDENCE=0.75
# Aggregat-Margin-Cap (C1): ab dieser Gesamt-Margin-Auslastung
# (totalMarginUsed/accountValue) werden NEUE Entries geskippt.
MAX_MARGIN_UTILIZATION=0.85

# ── Not-Halt ─────────────────────────────────────────────────────────────────
# Flag-DATEI (nicht true/false!): existiert sie, ignoriert die Engine alle
# Signale. Default: /var/lib/goathub/emergency-halt (LOW-11); Fallback
# /tmp/goathub-emergency-halt wenn das Verzeichnis fehlt (nur lokales Dev).
#EMERGENCY_HALT_FLAG_PATH=/var/lib/goathub/emergency-halt

# ── Token-Usage-Scraper (signal-bot-Logs) ────────────────────────────────────
# M-20: Pfad zum bot.log des TradingHub-Signal-Bots (TOKEN_USAGE-Zeilen für
# das Admin-Kosten-Dashboard). Default = der TradingHub-Docker-Volume-Pfad.
# TOKEN_SCRAPER_ENABLED default: nur an, wenn der Pfad beim Start existiert
# und lesbar ist — auf Hosts ohne das Volume bleibt der Scraper automatisch
# aus (eine Warnung, kein Error-Spam). Explizit true/false überstimmt das.
#TOKEN_USAGE_LOG_PATH=/var/lib/docker/volumes/tradinghub-signalbeta_signalbeta-data/_data/logs/bot.log
#TOKEN_SCRAPER_ENABLED=false
# Legacy-Alias (ältere .envs): wird als Fallback für TOKEN_USAGE_LOG_PATH gelesen.
SIGNALBOT_LOG_PATH=
